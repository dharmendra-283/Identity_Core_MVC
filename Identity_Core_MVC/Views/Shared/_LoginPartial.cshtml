@using Microsoft.AspNetCore.Identity;
@inject SignInManager<User> signInManager

<ulc class="navbar-nav">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown"
               role="button" data-bs-toggle="dropdown" arial-expanded="false">@User.Identity!.Name</a>
            <ul class="dropdown-menu" arial-labelleby="navbarDropdown">
                <li>
                    <a class="dropdown-item" asp-action="Logout" asp-controller="Account">Logout</a>
                    <a class="dropdown-item" asp-action="ChangePassword" asp-controller="Account">Change Password</a>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-action="Register" asp-controller="Account">Sign Up</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-action="Login" asp-controller="Account">Login</a>
        </li>
    }
</ulc>